FROM python:3.12-slim

WORKDIR /app

# Copy and install dependencies
COPY deploy/requirements.txt.lock .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt.lock

# Copy application code
COPY cellarium/ ./cellarium/

# Set Python path
ENV PYTHONPATH="/app"

# Create non-root user
RUN useradd -r -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Run admin service
CMD ["python", "-m", "cellarium.cas_backend.apps.admin.server"]
